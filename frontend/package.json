{
  "name": "transcriber",
  "version": "0.1.0",
  "description": "MP4 Transcriber - Electron + Vue 3",
  "author": "nanasi-apps",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n BACKEND,ELECTRON -c blue,cyan \"pnpm dev:backend\" \"pnpm dev:electron\"",
    "dev:backend": "cross-env PYTHONPATH=../backend/src uv run --project ../backend uvicorn transcriber.server:app --host 127.0.0.1 --port 8765 --reload",
    "dev:electron": "cross-env BACKEND_MANAGED_EXTERNALLY=true electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:mac": "pnpm build && electron-builder --mac",
    "lint": "oxlint --import-plugin --vue-plugin src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "~5.8.0",
    "vite": "^8.0.0",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "@electron/rebuild"
    ]
  }
}
